# OpenAI API key for optional LLM decisions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# SEC asks automated clients to identify themselves.
# Example: Your Name your.email@example.com
SEC_USER_AGENT=

# Optional: Alpaca paper-trading credentials. The local simulator works without these.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

